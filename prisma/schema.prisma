generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  company   String?
  status    String   @default("Prospect")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}